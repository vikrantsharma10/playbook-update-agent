# Playbook Update Agent — Configuration
# Fill in every value below before importing the workflow into n8n
# This file is for your reference only; the actual values go into n8n Environment Variables

# ─────────────────────────────────────────
# LLM
# ─────────────────────────────────────────
CLAUDE_API_KEY=your_claude_api_key_here
# Get this from: console.anthropic.com

# ─────────────────────────────────────────
# SLACK
# ─────────────────────────────────────────
SLACK_BOT_TOKEN=your_slack_bot_token_here
# Get this from: api.slack.com → Your App → OAuth & Permissions → Bot User OAuth Token

SLACK_CHANNEL_ID=your_slack_channel_id_here
# Get this from: Right-click the channel in Slack → View channel details → Channel ID at the bottom

# ─────────────────────────────────────────
# PLAYBOOK LOCATION
# Choose one of the three options below and leave the others blank
# ─────────────────────────────────────────

# OPTION 1 — Google Docs
GOOGLE_DOC_ID=your_google_doc_id_here
# Get this from: The long string in your Google Doc URL between /d/ and /edit

# OPTION 2 — Notion
NOTION_API_KEY=your_notion_api_key_here
NOTION_PAGE_ID=your_notion_page_id_here
# Get API key from: notion.so/my-integrations
# Get Page ID from: Open the page → click Share → Copy link → the ID is the last string in the URL

# OPTION 3 — Confluence
CONFLUENCE_API_TOKEN=your_confluence_api_token_here
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net
CONFLUENCE_PAGE_ID=your_confluence_page_id_here
# Get API token from: id.atlassian.com → Security → API tokens
# Get Page ID from: Open the page in Confluence → Page Information → Page ID in the URL

# ─────────────────────────────────────────
# CHANGE LOG (OPTIONAL)
# Only fill this in if you want a Google Sheet change log
# Leave blank to skip; Google Docs version history covers you regardless
# ─────────────────────────────────────────
GOOGLE_SHEET_ID=your_google_sheet_id_here
# Get this from: The long string in your Google Sheet URL between /d/ and /edit
