# Playbook Update Agent — Configuration
# Fill in every value below before importing the workflow into n8n
# This file is for your reference only; the actual values go into n8n Environment Variables

# ─────────────────────────────────────────
# LLM
# ─────────────────────────────────────────
CLAUDE_API_KEY=your_claude_api_key_here
# Get this from: console.anthropic.com

# ─────────────────────────────────────────
# SLACK
# ─────────────────────────────────────────
SLACK_BOT_TOKEN=your_slack_bot_token_here
# Get this from: api.slack.com → Your App → OAuth & Permissions → Bot User OAuth Token

SLACK_CHANNEL_ID=your_slack_channel_id_here
# Get this from: Right-click the channel in Slack → View channel details → Channel ID at the bottom

# ─────────────────────────────────────────
# PLAYBOOK LOCATION
# Fill in only the section that matches your platform; leave the others blank
# ─────────────────────────────────────────

# ── OPTION 1: Google Docs ──
GOOGLE_DOC_ID=your_google_doc_id_here
# Get this from: The string in your Google Doc URL between /d/ and /edit

# ── OPTION 2: Notion ──
NOTION_API_KEY=your_notion_integration_token_here
# Get this from: notion.so/my-integrations → your integration → Internal Integration Token

NOTION_PAGE_ID=your_notion_page_id_here
# Get this from: Open the page → copy the URL → the Page ID is the last string after the final dash

# ── OPTION 3: Confluence ──
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net
# This is your Atlassian domain; no trailing slash

CONFLUENCE_PAGE_ID=your_confluence_page_id_here
# Get this from: Open the page in Confluence → look at the URL → the number after pageId= is the Page ID

CONFLUENCE_AUTH_TOKEN=your_base64_encoded_auth_token_here
# This is your email and API token encoded in Base64 format
# How to generate it:
# 1. Get your API token from: id.atlassian.com → Security → API Tokens → Create token
# 2. Combine as: your_email@company.com:your_api_token
# 3. Base64 encode that string (use: base64encode.org)
# 4. Paste the result here

# ─────────────────────────────────────────
# CHANGE LOG (OPTIONAL)
# Only fill this in if you want a Google Sheet change log
# Leave blank to skip; all three platforms track version history natively
# ─────────────────────────────────────────
GOOGLE_SHEET_ID=your_google_sheet_id_here
# Get this from: The string in your Google Sheet URL between /d/ and /edit
# Create a sheet with a tab named exactly: Change Log
